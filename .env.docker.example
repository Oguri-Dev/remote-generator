# ===========================================================================
# Configuración de despliegue (docker-compose). Copiar a .env y completar.
# NUNCA subir .env a Git (ya está en .gitignore).
# ===========================================================================

# ===== Seguridad (OBLIGATORIO) =====
# Secreto para firmar las cookies de sesión (HMAC). >=16 chars.
# Generar con: openssl rand -base64 32
SESSION_SECRET=cambiar-por-una-cadena-aleatoria-larga

# Clave para cifrar en reposo las contraseñas (MQTT y cámara) en Mongo (AES-GCM).
# >=16 chars. Si cambia, las contraseñas guardadas dejan de descifrarse y hay
# que reintroducirlas. Generar con: openssl rand -base64 32
CONFIG_ENC_KEY=cambiar-por-otra-cadena-aleatoria-larga

# ===== Cámara WebRTC: IP del servidor en la red (ÚNICA variable de terreno) =====
# IP de ESTE servidor por la que el navegador del operador alcanza el vídeo.
# El vídeo WebRTC viaja por UDP directo navegador<->servidor, así que esta IP
# debe ser la del servidor en el segmento desde donde miran los operadores.
#
# En desarrollo (mismo PC):   WEBRTC_HOST=localhost
# En terreno:                 WEBRTC_HOST=<IP del servidor, ej. 10.1.1.50>
#
# Tras cambiarla, basta: docker compose up -d mediamtx   (NO requiere rebuild).
WEBRTC_HOST=localhost

# ===== Opcional =====
# Origen permitido para CORS del backend. Por defecto el backend acepta el mismo
# host. Si accedes por una IP concreta y tienes problemas de CORS, ponla aquí.
# FRONTEND_ORIGIN=http://10.1.1.50

# ---------------------------------------------------------------------------
# NOTA: la API, el WebSocket, el MQTT y la señalización de la cámara usan rutas
# RELATIVAS proxeadas por nginx, así que funcionan en CUALQUIER IP/segmento sin
# reconstruir nada. Lo único que depende del segmento es WEBRTC_HOST (arriba).
# ---------------------------------------------------------------------------
