# ===== Frontend Configuration =====
# URL del frontend accesible desde el navegador (usado por CORS en backend)
FRONTEND_ORIGIN=http://localhost

# ===== API Configuration =====
# URL de la API que el frontend usará en el navegador
# Debe ser la IP o dominio desde donde accedes (frontend en navegador)
VITE_API_BASE_URL=http://localhost:8099

# ===== Cámara (MediaMTX / WebRTC) =====
# URL base de WebRTC/WHEP de MediaMTX accesible DESDE EL NAVEGADOR.
# El reproductor compone: <VITE_MEDIAMTX_WHEP>/generador/whep
# Debe apuntar al puerto 8889 de MediaMTX en la IP/dominio accesible al cliente.
# EN PRODUCCIÓN: además de cambiar esto a la IP real, añade esa IP a
# webrtcAdditionalHosts en mediamtx.yml (si no, WebRTC no conectará).
VITE_MEDIAMTX_WHEP=http://localhost:8889

# ===== Seguridad =====
# Secreto para firmar las cookies de sesión (HMAC). OBLIGATORIO, >=16 chars.
# Generar con: openssl rand -base64 32
SESSION_SECRET=cambiar-por-una-cadena-aleatoria-larga

# Clave para cifrar en reposo las contraseñas MQTT en Mongo (AES-GCM).
# OBLIGATORIA, >=16 chars. Si cambia, las contraseñas guardadas dejan de
# descifrarse y hay que reintroducirlas. Generar con: openssl rand -base64 32
CONFIG_ENC_KEY=cambiar-por-otra-cadena-aleatoria-larga

# ===== Instrucciones =====
# 1. OBLIGATORIO: Actualiza FRONTEND_ORIGIN y VITE_API_BASE_URL
#    Ejemplo para red local (acceso desde 10.1.2.16):
#      FRONTEND_ORIGIN=http://10.1.2.16
#      VITE_API_BASE_URL=http://10.1.2.16:8099
#    Ejemplo para dominio (HTTPS):
#      FRONTEND_ORIGIN=https://tu-dominio.com
#      VITE_API_BASE_URL=https://tu-dominio.com/api
# 2. NUNCA subas .env a Git (ya está en .gitignore)
# 3. Después de cambiar valores, reinicia: docker-compose restart
