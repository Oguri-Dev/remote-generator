# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=generator
MONGODB_COLL=config

# Server Configuration
PORT=8099
FRONTEND_ORIGIN=http://localhost:3069

# Secreto para firmar las cookies de sesión (HMAC). OBLIGATORIO.
# Debe ser una cadena aleatoria de >=16 caracteres. Generar con, p.ej.:
#   openssl rand -base64 32
# Si cambia, todas las sesiones activas se invalidan.
SESSION_SECRET=cambiar-por-una-cadena-aleatoria-larga

# Clave para cifrar en reposo las contraseñas del broker MQTT (AES-GCM).
# OBLIGATORIA, >=16 caracteres. Generar con: openssl rand -base64 32
# IMPORTANTE: si cambia, las contraseñas ya guardadas en Mongo no se podrán
# descifrar y habrá que volver a introducirlas desde la configuración.
CONFIG_ENC_KEY=cambiar-por-otra-cadena-aleatoria-larga

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production   # en producción: cookies Secure y CORS/WS estrictos
